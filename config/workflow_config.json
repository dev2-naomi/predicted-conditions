{
  "phases": {
    "SCENARIO": {
      "order": 1,
      "steps": [0]
    },
    "DOCUMENT_NEEDS": {
      "order": 2,
      "steps": [1, 2, 3, 4, 5, 6, 7]
    },
    "FINALIZATION": {
      "order": 3,
      "steps": [8]
    }
  },
  "steps": {
    "STEP_00": {
      "name": "Scenario Builder",
      "description": "Parse MISMO XML, manifest documents, and eligibility output into scenario_summary; detect missing variables and contradictions; build document inventory; route docs and overlays to facets.",
      "plan_file": "step_00_scenario_builder.md",
      "substeps": [
        { "id": "0.1", "name": "Parse MISMO XML loan file", "tools": ["parse_loan_file"] },
        { "id": "0.2", "name": "Parse manifest documents", "tools": ["parse_manifest_documents"] },
        { "id": "0.3", "name": "Parse eligibility engine output", "tools": ["parse_eligibility_output"] },
        { "id": "0.4", "name": "Load doctype masterlist", "tools": ["load_doctype_masterlist"] },
        { "id": "0.5", "name": "Build scenario summary and detect contradictions", "tools": ["build_scenario_summary", "detect_contradictions"] },
        { "id": "0.6", "name": "Route docs and overlays to facets", "tools": ["route_to_facets"] },
        { "id": "0.7", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_01": {
      "name": "Cross-Cutting Document Needs Gatekeeper",
      "description": "Generate document requests for missing core variables, contradictions, overlay conflicts, and file-wide blockers.",
      "plan_file": "step_01_cross_cutting.md",
      "substeps": [
        { "id": "1.1", "name": "Load cross-cutting guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "1.2", "name": "Check overlay conflicts", "tools": ["check_overlay_conflicts"] },
        { "id": "1.3", "name": "Generate cross-cutting document requests", "tools": ["generate_crosscutting_document_requests"] },
        { "id": "1.4", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_02": {
      "name": "Income Document Needs Engine",
      "description": "Generate document requests for income qualification, calculation, stability, and documentation.",
      "plan_file": "step_02_income.md",
      "substeps": [
        { "id": "2.1", "name": "Load income guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "2.2", "name": "Generate income document requests", "tools": ["generate_income_document_requests"] },
        { "id": "2.3", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_03": {
      "name": "Assets Document Needs Engine",
      "description": "Generate document requests for funds to close, reserves, gifts, large deposits, sourcing, and asset ownership.",
      "plan_file": "step_03_assets.md",
      "substeps": [
        { "id": "3.1", "name": "Load assets guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "3.2", "name": "Generate asset document requests", "tools": ["generate_asset_document_requests"] },
        { "id": "3.3", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_04": {
      "name": "Credit Document Needs Engine",
      "description": "Generate document requests for credit report completeness, scores, tradelines, housing history, inquiries, disputes, and credit events.",
      "plan_file": "step_04_credit.md",
      "substeps": [
        { "id": "4.1", "name": "Load credit guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "4.2", "name": "Generate credit document requests", "tools": ["generate_credit_document_requests"] },
        { "id": "4.3", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_05": {
      "name": "Property and Appraisal Document Needs Engine",
      "description": "Generate document requests for appraisal, valuation, property type, LTV support, rent schedule, condo/PUD, inspections, and flood/property eligibility.",
      "plan_file": "step_05_property_appraisal.md",
      "substeps": [
        { "id": "5.1", "name": "Load property guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "5.2", "name": "Generate property document requests", "tools": ["generate_property_document_requests"] },
        { "id": "5.3", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_06": {
      "name": "Title and Closing Document Needs Engine",
      "description": "Generate document requests for title, vesting, lien position, payoff, escrow, insurance, taxes, closing disclosure, and settlement support.",
      "plan_file": "step_06_title_closing.md",
      "substeps": [
        { "id": "6.1", "name": "Load title guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "6.2", "name": "Generate title document requests", "tools": ["generate_title_document_requests"] },
        { "id": "6.3", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_07": {
      "name": "Compliance Document Needs Engine",
      "description": "Generate document requests for authorizations, affidavits, occupancy certifications, business purpose, ITIN support, identity, trust/entity docs.",
      "plan_file": "step_07_compliance.md",
      "substeps": [
        { "id": "7.1", "name": "Load compliance guideline sections", "tools": ["load_guideline_sections"] },
        { "id": "7.2", "name": "Generate compliance document requests", "tools": ["generate_compliance_document_requests"] },
        { "id": "7.3", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    },
    "STEP_08": {
      "name": "Document Request Merger and Ranker",
      "description": "Merge document requests from modules 01-07; aggregate specifications and reasons; de-duplicate; rank; produce final Predictive Document Needs List.",
      "plan_file": "step_08_merger_ranker.md",
      "substeps": [
        { "id": "8.1", "name": "Merge and de-duplicate document requests", "tools": ["merge_document_requests"] },
        { "id": "8.2", "name": "Rank document requests", "tools": ["rank_document_requests"] },
        { "id": "8.3", "name": "Generate final output", "tools": ["generate_final_output"] },
        { "id": "8.4", "name": "Save step report", "tools": ["save_step_report"] }
      ]
    }
  },
  "general_tools": [
    "write_todo",
    "get_workflow_status",
    "save_step_report"
  ],
  "middleware": {
    "summarization": { "enabled": true },
    "tool_filtering": { "enabled": true },
    "plan_injection": { "enabled": true },
    "max_tool_result_size": 30000
  },
  "dev_mode": {
    "enabled": false,
    "skip_steps": [],
    "cutoff_step": null,
    "run_only_substeps": []
  }
}
